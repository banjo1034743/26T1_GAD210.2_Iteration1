  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 131cfe9d38e82054c99c047280bbf615, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _authorName: 
  _datePublished: 0
  _packageDisplayName: 
  _packageNameTextField: {fileID: 334666556}
  _authorNameTextField: {fileID: 1498198889}
  _publishedDateTextField: {fileID: 1945166400}
  _creatureName: 
  _creatureDisplayImage: {fileID: 1138893455}
  _creatureImageSpace: {fileID: 1871102263}
  _creatureColor:
    serializedVersion: 2
    rgba: 0
  _powerDecriptions:
  - '"The user has the power to be 2nd-Dimensional, existing in lower-dimensional
    layers or operating uniquely when on worlds like 3rd Dimension." <i>From the
    Superpower Wiki</i>'
  - '"This technique allows the user to divide one second into twenty-four frames
    and trace a predetermined set of movements to execute in that second. It uses
    the user''s field of view as the projection angle of view. While Projection Sorcery
    is active, anything touched by Naobito''s palm must abide by the 24FPS as well
    or they will get frozen for one second inside an animation frame. Naobito uses
    this technique to appear to move faster than the eye can see in addition to freezing
    any adversaries that can''t keep up with his speed." <i>From the Jujutsu Kaisen
    Wiki</i> '
  - '"The user''s form has been altered for the better. Upgraded form has a wide
    variety of enhancements. Upgraded forms are mostly gained from technology." <i>From
    the Superpower Wiki</i>'
  - '"The user as a way with words, being able to convince almost anyone to meet
    the user''s desries and requests."'
  - '"The user has the ability to save moments in time (usually the current moment)
    and load them back, either consciously or automatically upon death." <i>From
    the Superpower Wiki</i>'
  - '"The user possesses complete control over all technology and devices and can
    create and manipulate technology, the sum of techniques, skills, methods, and
    processes used in the production of goods or services or in the accomplishment
    of objectives." <i>From the Superpower Wiki</i>'
  - '"The user can instantly and perfectly replicate themselves and/or other entities
    and even objects, often numerous times without losing energy or getting tired."
    <i>From the Superpower Wiki</i>'
  - '"The user can teleport absolutely anything to literally anywhere: any place
    and time they desire, including physical locations such as: in a locked room,
    in space, a planet, a galaxy or a universe as well as metaphysical locations
    such as: in Heaven, in Hell, inside a dream, inside a heart, inside thoughts,
    and even inside people or yourself." <i>From the Superpower Wiki</i>'
  - '"The user has prehensility on all parts of their body, (head, forearms, fore
    legs, back, torso, etc.) that would not be able to normally grasp and manipulate
    objects with the ease of doing so with the hands." <i>From the Superpower Wiki</i>'
  - '"The user can manipulate the prehensility of body parts, making it so that body
    parts are more prehensile and are capable of interacting with other objects like
    the hands are. In some cases, the user can extend this prehensility to objects."
    <i>From the Superpower Wiki</i>'
  - '"Users can produce something either out of nothing or from existing sources."
    <i>From the Superpower Wiki</i>'
  - '"Users possess vast amounts of strength, being able to easily destroy entire
    cities with their punches, or perhaps even destroy planets in some cases." <i>From
    the Superpower Wiki</i>'
  _creatureNameTextField: {fileID: 504057075}
  _creaturePowerNameTextField: {fileID: 1278212533}
  _creaturePowerDescTextField: {fileID: 969675165}
  _creatureSprite2D: {fileID: 21300000, guid: 7d3c5316398fd50499d378f8655b2113, type: 3}
  _creatureSprite3D: {fileID: 21300000, guid: e8329724f6ed54142bd99f22434cefa1, type: 3}
